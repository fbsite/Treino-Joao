<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HyperGrowth - João (Treino ABC)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #020617;
            color: #f8fafc;
            -webkit-tap-highlight-color: transparent;
            overflow-x: hidden;
        }
        .glass-card {
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .nav-active {
            color: #10b981;
        }
        .nav-active::after {
            content: '';
            position: absolute;
            top: -4px;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 3px;
            background: #10b981;
            border-radius: 10px;
            box-shadow: 0 0 10px #10b981;
        }
        .progress-bar-fill {
            transition: width 1s ease-in-out;
        }
        .set-pill {
            transition: all 0.2s ease;
        }
        .set-pill.completed {
            background-color: #10b981;
            color: #020617;
            border-color: #10b981;
            transform: scale(1.1);
        }
        input:focus {
            outline: none;
            border-color: #10b981;
        }
        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
    </style>
</head>
<body class="pb-24">

    <!-- Modal de Cronómetro -->
    <div id="timerModal" class="fixed inset-0 bg-black/95 z-50 flex items-center justify-center p-6 hidden">
        <div class="glass-card p-10 rounded-[3rem] w-full max-w-xs text-center border-emerald-500/30">
            <p class="text-emerald-500 text-xs font-black uppercase tracking-widest mb-4">Descanso Ativo</p>
            <div id="timerDisplay" class="text-7xl font-mono text-white mb-10">01:30</div>
            <button onclick="closeTimer()" class="w-full py-5 bg-emerald-600 hover:bg-emerald-500 text-white rounded-2xl font-black shadow-lg shadow-emerald-900/40">
                PULAR DESCANSO
            </button>
        </div>
    </div>

    <!-- App Container -->
    <div class="max-w-md mx-auto px-6 pt-8">
        
        <!-- Header -->
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-black italic uppercase tracking-tighter leading-none">HyperGrowth</h1>
                <p class="text-slate-500 text-[10px] font-black uppercase tracking-[0.2em] mt-1">Atleta: João (Treino ABC)</p>
            </div>
            <div class="bg-emerald-500/10 p-3 rounded-2xl border border-emerald-500/20">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.292 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            </div>
        </header>

        <!-- View: Dashboard -->
        <div id="view-dashboard" class="space-y-6 animate-in fade-in duration-500">
            <!-- Card de Meta/Data -->
            <div class="bg-gradient-to-br from-emerald-600 to-emerald-900 p-8 rounded-[2.5rem] shadow-2xl relative overflow-hidden">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <p class="text-white/60 text-[10px] font-black uppercase tracking-widest">Plano de Treino</p>
                            <h2 class="text-white font-black text-xl italic mt-1">Meta: 75kg (Ganho Massivo)</h2>
                        </div>
                    </div>
                    <div class="w-full bg-black/20 h-2 rounded-full overflow-hidden mb-2">
                        <div id="dateProgressBar" class="progress-bar-fill bg-emerald-400 h-full w-0"></div>
                    </div>
                    <div class="flex justify-between text-[10px] text-white/50 font-bold uppercase tracking-tighter">
                        <span>23/03/26 (Início)</span>
                        <span>23/05/26 (Meta)</span>
                    </div>
                </div>
                <svg class="absolute -bottom-6 -right-6 text-white/10 rotate-12" width="140" height="140" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>

            <!-- Frase Motivacional -->
            <div class="glass-card p-5 rounded-3xl border-l-4 border-l-emerald-500">
                <p id="motivationalQuote" class="text-slate-300 italic text-sm font-medium">"A consistência é o que transforma o desejo em realidade."</p>
            </div>

            <!-- Estatísticas Rápidas -->
            <div class="grid grid-cols-2 gap-4">
                <div class="glass-card p-5 rounded-3xl">
                    <p class="text-slate-500 text-[10px] font-black uppercase mb-1 tracking-widest">Peso Atual</p>
                    <div class="flex items-baseline gap-1">
                        <span id="statWeight" class="text-3xl font-black text-white">68</span>
                        <span class="text-slate-500 text-xs font-bold uppercase">kg</span>
                    </div>
                </div>
                <div class="glass-card p-5 rounded-3xl">
                    <p class="text-slate-500 text-[10px] font-black uppercase mb-1 tracking-widest">Idade</p>
                    <div class="flex items-baseline gap-1">
                        <span id="statAge" class="text-3xl font-black text-emerald-400">27</span>
                        <span class="text-slate-500 text-xs font-bold uppercase italic">Anos</span>
                    </div>
                </div>
            </div>

            <!-- Lista de Treinos ABC -->
            <section>
                <h2 class="text-white font-black text-xs uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15h12M6 9h12M3 21h18M3 3h18"/></svg>
                    Divisão ABC (3x na Semana)
                </h2>
                <div class="space-y-4" id="workoutList">
                    <!-- Gerado via JS -->
                </div>
            </section>
        </div>

        <!-- View: Workout Detail -->
        <div id="view-workout-detail" class="hidden space-y-6 animate-in slide-in-from-right duration-300">
            <button onclick="showView('dashboard')" class="flex items-center gap-2 text-slate-500 bg-slate-900 px-4 py-2 rounded-full border border-white/5 active:scale-95 transition-all mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Voltar
            </button>
            <div id="workoutHeader"></div>
            <div id="exerciseList" class="space-y-4"></div>
            <button onclick="finishWorkout()" class="w-full mt-10 py-5 bg-emerald-600 rounded-[2rem] font-black text-xl shadow-xl shadow-emerald-950/50 active:scale-95 transition-all">
                CONCLUIR TREINO
            </button>
        </div>

        <!-- View: Tips -->
        <div id="view-tips" class="hidden space-y-6 animate-in fade-in duration-300">
            <h2 class="text-3xl font-black text-white pt-2 italic tracking-tighter">Dicas do Personal</h2>
            <div id="tipsContainer" class="space-y-4"></div>
        </div>

        <!-- View: Profile -->
        <div id="view-profile" class="hidden space-y-6 animate-in fade-in duration-300">
            <h2 class="text-3xl font-black text-white pt-2 italic tracking-tighter">Evolução João</h2>
            <div class="glass-card p-8 rounded-[2.5rem] flex items-center justify-between shadow-xl">
                <div class="flex items-center gap-5">
                    <div class="w-16 h-16 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-500 border border-blue-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 12h10M5 12a2 2 0 1 0 0 4h14a2 2 0 1 0 0-4M8 8a4 4 0 1 1 8 0c0 4-4 6-4 6s-4-2-4-6Z"/></svg>
                    </div>
                    <div>
                        <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">IMC Estimado</p>
                        <p id="bmiDisplay" class="text-4xl font-black text-white tracking-tighter">--</p>
                    </div>
                </div>
            </div>

            <div class="glass-card rounded-[2.5rem] p-8 space-y-6">
                <div>
                    <label class="text-slate-500 text-[10px] font-black uppercase block mb-3 px-1 tracking-[0.2em]">Peso Atual (kg)</label>
                    <input id="inputWeight" type="number" class="w-full bg-slate-950 border border-white/10 rounded-2xl px-6 py-5 text-white font-black text-lg shadow-inner">
                </div>
                <div>
                    <label class="text-slate-500 text-[10px] font-black uppercase block mb-3 px-1 tracking-[0.2em]">Altura (m)</label>
                    <input id="inputHeight" type="number" step="0.01" class="w-full bg-slate-950 border border-white/10 rounded-2xl px-6 py-5 text-white font-black text-lg shadow-inner">
                </div>
                <div>
                    <label class="text-slate-500 text-[10px] font-black uppercase block mb-3 px-1 tracking-[0.2em]">Idade</label>
                    <input id="inputAge" type="number" class="w-full bg-slate-950 border border-white/10 rounded-2xl px-6 py-5 text-white font-black text-lg shadow-inner">
                </div>
                <button onclick="saveProfile()" class="w-full py-4 bg-emerald-600 rounded-2xl font-black text-white shadow-lg active:scale-95 transition-all">ATUALIZAR DADOS</button>
            </div>
        </div>

    </div>

    <!-- Navegação Inferior -->
    <nav class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[92%] max-w-sm glass-card h-20 rounded-[2.5rem] flex items-center justify-around px-6 z-40 shadow-2xl overflow-hidden border-white/10">
        <button onclick="showView('dashboard')" id="nav-dashboard" class="nav-btn flex flex-col items-center justify-center w-16 relative text-slate-500 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 15h12M6 9h12M3 21h18M3 3h18"/></svg>
            <span class="text-[9px] font-black mt-1 uppercase tracking-tighter">Treino</span>
        </button>
        <button onclick="showView('tips')" id="nav-tips" class="nav-btn flex flex-col items-center justify-center w-16 relative text-slate-500 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            <span class="text-[9px] font-black mt-1 uppercase tracking-tighter">Dicas</span>
        </button>
        <button onclick="showView('profile')" id="nav-profile" class="nav-btn flex flex-col items-center justify-center w-16 relative text-slate-500 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="text-[9px] font-black mt-1 uppercase tracking-tighter">Perfil</span>
        </button>
    </nav>

    <script>
        // --- Dados e Estado ---
        const START_DATE = new Date('2026-03-23');
        const END_DATE = new Date('2026-05-23');
        
        const QUOTES = [
            "Não pares até estares orgulhoso.",
            "O músculo cresce no descanso, mas ganha-se na luta.",
            "Para teres resultados diferentes, tens de fazer treinos diferentes.",
            "O teu corpo aguenta quase tudo, é a tua mente que tens de convencer.",
            "Consistência é o segredo dos 75kg."
        ];

        const TIPS = [
            { t: "Foco no Superavit", d: "João, com 68kg o teu maior inimigo é a falta de calorias. Come limpo, mas come muito." },
            { t: "Progressão ABC", d: "Como o treino é dividido, tenta levar cada músculo à falha técnica entre a 8ª e 12ª repetição." },
            { t: "Tempo de Tensão", d: "Não tenhas pressa na descida do peso. Controla a fase excêntrica para rasgar as fibras." },
            { t: "Recuperação", d: "Dorme 8h. O teu corpo é um laboratório anabólico durante a noite." }
        ];

        const WORKOUTS = [
            {
                id: 'a',
                title: 'Treino A - Empurrar (Peito/Ombro/Tríceps)',
                icon: '⚡',
                exercises: [
                    { n: 'Supino Reto (Barra)', s: '4x8-10', r: 90, d: 'Foco em explosão na subida e controlo na descida.', i: '🏋️' },
                    { n: 'Supino Inclinado (Halteres)', s: '3x10-12', r: 60, d: 'Trabalha a parte superior do peito para preencher o tórax.', i: '📈' },
                    { n: 'Desenvolvimento (Halteres)', s: '3x10', r: 60, d: 'Mantém o core contraído para proteger a lombar.', i: '💪' },
                    { n: 'Elevação Lateral', s: '3x15', r: 45, d: 'Foco no deltóide lateral para ombros largos.', i: '🦅' },
                    { n: 'Tríceps Corda', s: '3x12', r: 60, d: 'Abre a corda no final do movimento para contração máxima.', i: '⛓️' }
                ]
            },
            {
                id: 'b',
                title: 'Treino B - Puxar (Costas/Bíceps/Post.)',
                icon: '🔥',
                exercises: [
                    { n: 'Remada Curvada (Barra)', s: '4x10', r: 90, d: 'Mantém as costas seladas e puxa para o umbigo.', i: '🛶' },
                    { n: 'Puxada Dorsal Alta', s: '4x10', r: 90, d: 'Foco em fechar as escápulas, não puxes só com o braço.', i: '🧗' },
                    { n: 'Remada Baixa (Triângulo)', s: '3x12', r: 60, d: 'Sente o alongamento das costas na volta.', i: '🚜' },
                    { n: 'Rosca Direta (Barra W)', s: '3x12', r: 60, d: 'Evita balançar o corpo, isola o bíceps.', i: '🧪' },
                    { n: 'Face Pull', s: '3x15', r: 45, d: 'Puxa em direção à testa para deltoide posterior.', i: '👺' }
                ]
            },
            {
                id: 'c',
                title: 'Treino C - Pernas e Abdominais',
                icon: '🦵',
                exercises: [
                    { n: 'Agachamento Livre', s: '4x10', r: 120, d: 'O rei dos exercícios. Mantém o peito alto e desce bem.', i: '👑' },
                    { n: 'Leg Press 45', s: '3x12', r: 90, d: 'Não traves os joelhos no final da subida.', i: '📉' },
                    { n: 'Cadeira Extensora', s: '3x15', r: 45, d: 'Pausa de 1s no topo para contração total.', i: '🪑' },
                    { n: 'Mesa Flexora', s: '3x15', r: 45, d: 'Controla a descida para trabalhar o posterior.', i: '🔗' },
                    { n: 'Panturrilha em Pé', s: '4x15', r: 45, d: 'Amplitude total: desce tudo e sobe tudo.', i: '🦶' },
                    { n: 'Abdominal Supra', s: '3x20', r: 45, d: 'Solta o ar na subida e contrai o abdómen.', i: '🧱' }
                ]
            }
        ];

        let state = JSON.parse(localStorage.getItem('hg_joao_state_abc_v3')) || {
            weight: 68,
            height: 1.77,
            age: 27,
            count: 0,
            lastWorkout: null
        };

        // --- Lógica do Timer ---
        let timerInterval;
        function startTimer(seconds) {
            clearInterval(timerInterval);
            document.getElementById('timerModal').classList.remove('hidden');
            let timeLeft = seconds;
            
            const updateUI = () => {
                const m = Math.floor(timeLeft / 60);
                const s = timeLeft % 60;
                document.getElementById('timerDisplay').textContent = `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
            };

            updateUI();
            timerInterval = setInterval(() => {
                timeLeft--;
                updateUI();
                if (timeLeft <= 0) closeTimer();
            }, 1000);
        }

        function closeTimer() {
            clearInterval(timerInterval);
            document.getElementById('timerModal').classList.add('hidden');
        }

        // --- Navegação e UI ---
        function showView(viewId) {
            document.querySelectorAll('[id^="view-"]').forEach(v => v.classList.add('hidden'));
            document.getElementById(`view-${viewId}`).classList.remove('hidden');
            
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('nav-active'));
            document.getElementById(`nav-${viewId}`).classList.add('nav-active');

            if(viewId === 'dashboard') updateDashboard();
            if(viewId === 'profile') loadProfileInputs();
            if(viewId === 'tips') loadTips();
        }

        function updateDashboard() {
            document.getElementById('statWeight').textContent = state.weight;
            document.getElementById('statAge').textContent = state.age;
            
            // Lógica de Datas e Progresso
            const now = new Date();
            const totalDays = Math.ceil(Math.abs(END_DATE - START_DATE) / (1000 * 60 * 60 * 24));
            
            let diffDays;
            if (now < START_DATE) {
                diffDays = 0;
            } else {
                diffDays = Math.ceil(Math.abs(now - START_DATE) / (1000 * 60 * 60 * 24));
            }
            
            const progress = Math.min(100, Math.max(0, (diffDays / totalDays) * 100));
            document.getElementById('dateProgressBar').style.width = `${progress}%`;

            // Lista de Treinos ABC
            const list = document.getElementById('workoutList');
            list.innerHTML = '';
            WORKOUTS.forEach(w => {
                const btn = document.createElement('button');
                btn.className = "w-full group flex items-center justify-between glass-card p-6 rounded-[2rem] active:scale-95 transition-all";
                btn.onclick = () => openWorkout(w);
                btn.innerHTML = `
                    <div class="flex items-center gap-5">
                        <div class="w-16 h-16 bg-slate-950 rounded-2xl flex items-center justify-center text-3xl border border-white/5">${w.icon}</div>
                        <div class="text-left">
                            <p class="text-white font-black text-xl tracking-tight">${w.title}</p>
                            <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest">${w.exercises.length} Exercícios</p>
                        </div>
                    </div>
                    <svg class="text-slate-700" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                `;
                list.appendChild(btn);
            });
        }

        function toggleSet(pill) {
            pill.classList.toggle('completed');
        }

        function openWorkout(workout) {
            const header = document.getElementById('workoutHeader');
            header.innerHTML = `<h2 class="text-3xl font-black italic uppercase text-emerald-500 tracking-tighter">${workout.title}</h2><p class="text-slate-500 text-sm">Foco Hipertrofia Intermediário (João)</p>`;
            
            const list = document.getElementById('exerciseList');
            list.innerHTML = '';
            workout.exercises.forEach((ex, exIdx) => {
                const numSets = parseInt(ex.s.split('x')[0]) || 0;
                let setSlotsHtml = '';
                
                for(let i = 1; i <= numSets; i++) {
                    setSlotsHtml += `
                        <button onclick="toggleSet(this)" class="set-pill w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-xs font-bold text-slate-400 glass-card">
                            ${i}
                        </button>
                    `;
                }

                const div = document.createElement('div');
                div.className = "glass-card rounded-[2rem] overflow-hidden shadow-lg mb-4";
                div.innerHTML = `
                    <div class="p-6 flex gap-5">
                        <div class="text-4xl bg-emerald-500/10 w-20 h-20 rounded-2xl flex items-center justify-center border border-emerald-500/20 shrink-0">${ex.i}</div>
                        <div class="flex-1">
                            <div class="flex justify-between items-start">
                                <h3 class="font-bold text-lg text-white">${ex.n}</h3>
                                <button onclick="startTimer(${ex.r})" class="p-2.5 bg-emerald-600/20 rounded-xl text-emerald-400 active:scale-90 transition-transform">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                </button>
                            </div>
                            <div class="flex gap-3 mt-2">
                                <span class="bg-emerald-600 text-[10px] font-black px-2 py-0.5 rounded text-white tracking-widest uppercase">${ex.s}</span>
                                <span class="text-slate-500 text-xs font-bold">${ex.r}s Descanso</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="px-6 pb-6 pt-2">
                        <p class="text-slate-500 text-[10px] font-black uppercase tracking-widest mb-3">Check-in de Séries:</p>
                        <div class="flex flex-wrap gap-3">
                            ${setSlotsHtml}
                        </div>
                    </div>

                    <div class="bg-black/20 p-4 border-t border-white/5 flex gap-3 text-slate-400 text-xs italic">
                        <svg class="shrink-0 text-emerald-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                        ${ex.d}
                    </div>
                `;
                list.appendChild(div);
            });
            showView('workout-detail');
        }

        function finishWorkout() {
            state.count++;
            saveState();
            showView('dashboard');
        }

        function loadTips() {
            const container = document.getElementById('tipsContainer');
            container.innerHTML = '';
            TIPS.forEach(tip => {
                const div = document.createElement('div');
                div.className = "glass-card p-6 rounded-[2rem] flex gap-5 shadow-md";
                div.innerHTML = `
                    <div class="bg-emerald-500/10 p-3 h-fit rounded-2xl text-emerald-500 border border-emerald-500/20">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div>
                        <h3 class="text-emerald-400 font-black text-lg mb-1 tracking-tight">${tip.t}</h3>
                        <p class="text-slate-400 text-sm leading-relaxed">${tip.d}</p>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function loadProfileInputs() {
            document.getElementById('inputWeight').value = state.weight;
            document.getElementById('inputHeight').value = state.height;
            document.getElementById('inputAge').value = state.age;
            calculateBMI();
        }

        function saveProfile() {
            state.weight = parseFloat(document.getElementById('inputWeight').value) || 0;
            state.height = parseFloat(document.getElementById('inputHeight').value) || 0;
            state.age = parseInt(document.getElementById('inputAge').value) || 0;
            saveState();
            calculateBMI();
            showView('dashboard');
        }

        function calculateBMI() {
            if (state.height > 0) {
                const bmi = (state.weight / (state.height * state.height)).toFixed(1);
                document.getElementById('bmiDisplay').textContent = bmi;
            }
        }

        function saveState() {
            localStorage.setItem('hg_joao_state_abc_v3', JSON.stringify(state));
        }

        // --- Inicialização ---
        updateDashboard();
    </script>
</body>
</html>